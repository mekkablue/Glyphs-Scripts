		"threshold": 4,
		"checkBaseline": 1,
		"checkXHeight": 1,
		"checkCapHeight": 1,
		"checkAscender": 1,
		"checkDescender": 1,
		"checkAlignmentZones": 1,
		"includeNonExporting": 0,
		"markNodes": 0,
	}

	def __init__(self):
		windowWidth = 280
		windowHeight = 265
		self.w = vanilla.FloatingWindow(
			(windowWidth, windowHeight),
			"Find Near Vertical Misses",
			autosaveName=self.domain("mainwindow"),
		)

		indent = 15
		y = 10

